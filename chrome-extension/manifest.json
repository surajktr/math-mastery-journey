{
  "manifest_version": 3,
  "name": "Draw History Analyzer & Auto-Clicker",
  "version": "1.0",
  "description": "Analyzes draw patterns (Big/Small) and automates clicking actions on configurable streak thresholds.",
  "permissions": [
    "storage"
  ],
  "host_permissions": [
    "http://localhost:8787/*"
  ],
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "all_frames": true,
      "run_at": "document_end"
    }
  ],
  "action": {
    "default_popup": "popup.html",
    "default_title": "Draw History Analyzer"
  }
}
